{
  "uid": "virtual-portfolios",
  "title": "Investment Tracker — Virtual Portfolios",
  "tags": ["investments", "virtual-portfolios"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1h",
  "editable": true,
  "templating": {
    "list": [
      {
        "name": "DS_SQLITE",
        "label": "SQLite datasource",
        "type": "datasource",
        "query": "frser-sqlite-datasource",
        "current": { "text": "SQLite", "value": "SQLite" },
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total value (incl. virtuals)",
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "targets": [
        { "refId": "A", "rawQuery": true, "format": "table",
          "query": "SELECT SUM(combined_total) AS value FROM v_virtual_portfolio_rollup" }
      ],
      "fieldConfig": { "defaults": { "decimals": 0, "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green" }, { "color": "super-light-green", "value": 0 } ] } },
        "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto", "textMode": "value" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Physical own value",
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "targets": [
        { "refId": "A", "rawQuery": true, "format": "table",
          "query": "SELECT SUM(own_total) AS value FROM v_virtual_portfolio_rollup" }
      ],
      "fieldConfig": { "defaults": { "decimals": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Virtual total value",
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "targets": [
        { "refId": "A", "rawQuery": true, "format": "table",
          "query": "SELECT SUM(virtual_total) AS value FROM v_virtual_portfolio_rollup" }
      ],
      "fieldConfig": { "defaults": { "decimals": 0, "color": { "mode": "fixed", "fixedColor": "purple" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Virtual portfolios",
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "targets": [
        { "refId": "A", "rawQuery": true, "format": "table",
          "query": "SELECT COUNT(*) AS value FROM accounts WHERE COALESCE(is_virtual, 0) = 1" }
      ],
      "fieldConfig": { "defaults": { "decimals": 0, "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 }
    },
    {
      "id": 5,
      "type": "table",
      "title": "Accounts (physical incl. virtual children)",
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "targets": [
        { "refId": "A", "rawQuery": true, "format": "table",
          "query": "SELECT parent_display_name AS \"account\", own_cash AS \"own cash\", own_assets AS \"own assets\", own_total AS \"own total\", virtual_total AS \"virtual total\", combined_total AS \"combined total\", virtual_count AS \"# virtual\" FROM v_virtual_portfolio_rollup ORDER BY combined_total DESC" }
      ],
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 }
    },
    {
      "id": 6,
      "type": "table",
      "title": "Per-account valuations",
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "targets": [
        { "refId": "A", "rawQuery": true, "format": "table",
          "query": "SELECT display_name AS \"account\", CASE WHEN is_virtual = 1 THEN '[V]' ELSE '' END AS type, parent_account, cash, assets, total FROM v_account_current_valuations ORDER BY is_virtual, parent_account, total DESC" }
      ],
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 }
    },
    {
      "id": 7,
      "type": "table",
      "title": "Holdings by family (parent + its virtuals)",
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "targets": [
        { "refId": "A", "rawQuery": true, "format": "table",
          "query": "SELECT COALESCE(NULLIF(parent_account, ''), account) AS family, asset_name, SUM(held_amount) AS shares FROM v_account_asset_holdings GROUP BY family, asset_name ORDER BY family, shares DESC" }
      ],
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 13 }
    },
    {
      "id": 8,
      "type": "table",
      "title": "Recent capital flows (origin: avanza = real, virtual = internal)",
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "targets": [
        { "refId": "A", "rawQuery": true, "format": "table",
          "query": "SELECT date, account, transaction_type AS type, origin, flow_amount AS amount FROM v_external_capital_flows ORDER BY date DESC LIMIT 100" }
      ],
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 13 }
    }
  ]
}
